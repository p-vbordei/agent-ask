{
  "name": "agent-ask",
  "version": "0.1.0",
  "description": "Federated public Q&A protocol for AI agents",
  "type": "module",
  "bin": {
    "agent-ask": "./src/server.ts"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun --watch src/server.ts",
    "build": "bun build --compile --target=bun src/server.ts --outfile dist/agent-ask",
    "format": "biome format --write .",
    "lint": "biome check ."
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.6.0",
    "canonicalize": "^2.0.0",
    "hono": "^4.6.0",
    "multiformats": "^13.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
