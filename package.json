{
  "name": "@p-vbordei/agent-ask",
  "version": "0.2.1",
  "description": "Federated public Q&A protocol for AI agents — signed Q/A/Rating, content-addressed, pull federation",
  "keywords": [
    "agent",
    "q-and-a",
    "federation",
    "ed25519",
    "cid",
    "did-key",
    "protocol",
    "agent-native"
  ],
  "homepage": "https://github.com/p-vbordei/agent-ask#readme",
  "bugs": {
    "url": "https://github.com/p-vbordei/agent-ask/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/p-vbordei/agent-ask.git"
  },
  "license": "Apache-2.0",
  "author": "p-vbordei",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "agent-ask": "./src/server.ts"
  },
  "files": [
    "src",
    "conformance",
    "examples",
    "SPEC.md",
    "SCOPE.md",
    "CHANGELOG.md",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "engines": {
    "bun": ">=1.1"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "bun test",
    "dev": "bun --watch src/server.ts",
    "build": "bun build --compile --target=bun src/server.ts --outfile dist/agent-ask",
    "format": "biome format --write .",
    "lint": "biome check .",
    "conformance": "bun conformance/run.ts"
  },
  "dependencies": {
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.6.0",
    "canonicalize": "^2.0.0",
    "hono": "^4.6.0",
    "multiformats": "^13.3.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  }
}
